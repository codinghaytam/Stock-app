' ===========================
' RELATIONSHIPS
' ===========================

' User <-> Vehicle (Seller login via plate)
User "1" -- "0..1" Vehicle : "linked seller account"

' Transaction relationships
Transaction "many" --> "1" Vehicle : "vehicleId (optional)"
Transaction "many" --> "0..1" BankAccount : "bankAccountId (if wire)"
Transaction "1" *-- "0..*" TankDistribution : "tankDistributions"
TankDistribution "many" --> "1" Tank : "tankId"

' Stock loading
Vehicle "1" *-- "0..*" MobileStockItem : "mobileStock"
MobileStockItem "many" --> "1" StockItem : "references"

' Contract
Contract "1" *-- "1..*" ContractAllocation : "allocations"
ContractAllocation "many" --> "1" Tank : "sourceId"

' Invoice
Invoice "1" *-- "1..*" InvoiceItem : "items"

' Employee
Employee "1" -- "0..*" AttendanceRecord : "attendance"
Employee "1" -- "0..*" SalaryPayment : "salaryPayments"
SalaryPayment "0..1" --> "0..1" BankAccount : "bankAccountId"

' Email
EmailAccount "1" -- "0..*" EmailMessage : "messages"

' Fuel
FuelLog "0..*" --> "0..1" Vehicle : "vehicleId (optional)"

' Services use domain
AuthService ..> User
StockService ..> StockItem
TankService ..> Tank
TransactionService ..> Transaction
ProductionService ..> StockItem
ProductionService ..> Tank
AccountingService ..> Expense
AccountingService ..> BankCheck
AccountingService ..> BankAccount
AccountingService ..> Transaction
VehicleService ..> Vehicle
VehicleService ..> MobileStockItem
VehicleService ..> StockItem
HRService ..> Employee
HRService ..> AttendanceRecord
HRService ..> SalaryPayment
FuelService ..> FuelLog
ContractService ..> Contract
InvoiceService ..> Invoice
EmailService ..> EmailMessage
EmailService ..> EmailAccount
DashboardService ..> DashboardStats
DashboardService ..> SystemAlerts
ActivityLogService ..> ActivityLog

' DTOs
VehicleService ..> SellerStats
VehicleService ..> MobileSaleRequest
VehicleService ..> LoadItemRequest
TransactionService ..> PartnerSummary
ContractService ..> ContractStats
DashboardService ..> ChartDataPoint
MobileSaleRequest *-- CartItem

note top of AuthService
  Super Admins: mojo, boss (full access)
  Restricted Admins: hajar, safae (no financials)
  Sellers: login via vehicle plate number
  Blocked users cannot authenticate
end note

note right of Tank
  avgCost is recalculated using
  weighted average on each purchase
  or production filling operation.
end note

note bottom of Transaction
  priceTotal is always stored in MAD.
  originalAmount + currency + exchangeRate
  allow multi-currency tracking.
end note

note right of Contract
  Progress tracked via total allocated
  quantity vs targetQuantity.
  Status auto-set to TERMINE
  when fully allocated.
end note

note bottom of AccountingService
  Caisse Usine = ESPECE flows
  Caisse Directeur = CAISSE_DIRECTEUR flows
  Both are derived from transactions + expenses.
  NOT stored as separate ledger fields.
end note

@enduml

