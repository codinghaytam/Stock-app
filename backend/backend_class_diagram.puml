  }

  ' ----- ACTIVITY LOG -----
  class ActivityLog {
    - Long id
    - LocalDateTime date
    - String username
    - String action
    - String details
    - Double financialAmount
    --
    + boolean hasFinancialImpact()
  }

  ' ----- EMAIL ACCOUNT -----
  class EmailAccount {
    - Long id
    - String email
    - String displayName
    - String colorCode
    --
    + boolean isInternal()
    + long getUnreadCount()
  }

  ' ----- EMAIL MESSAGE -----
  class EmailMessage {
    - Long id
    - EmailFolder folder
    - String fromAddress
    - String toAddress
    - String subject
    - String body
    - LocalDateTime sentAt
    - boolean isRead
    --
    + void markAsRead()
    + void moveToTrash()
