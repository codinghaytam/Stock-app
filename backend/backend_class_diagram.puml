' ===========================
' PACKAGE: Core Domain Models
' ===========================
package "domain" #EAF5E5 {

  ' ----- USER MANAGEMENT -----
  class User {
    - Long id
    - String username
    - String passwordHash
    - UserRole role
    - boolean isBlocked
    - LocalDateTime createdAt
    - LocalDateTime lastLogin
    --
    + boolean isAccessAllowed()
    + boolean isSuperAdmin()
    + boolean isRestrictedAdmin()
  }

  ' ----- TANK (CITERNE) -----
  class Tank {
    - Long id
    - String name
    - double capacity
    - double currentLevel
    - double acidity
    - double waxes
    - double avgCost
    - TankStatus status
    --
    + double getUsagePercentage()
    + double getStockValue()
    + double getAvailableCapacity()
    + void updateWeightedAverages(double addedQty, double addedAcidity, double addedWaxes, double addedCost)
    + void recalculateStatus()
  }

  ' ----- STOCK ITEM -----
  class StockItem {
    - Long id
    - String name
    - ProductType type
    - double quantity
    - String unit
    - Brand brand
    - String bottleSize
    --
    + boolean isBottle()
    + boolean hasEnoughStock(double requestedQty)
    + void addQuantity(double qty)
    + void removeQuantity(double qty)
  }

  ' ----- VEHICLE -----
  class Vehicle {
    - Long id
    - String plateNumber
    - String driverName
    - VehicleType type
    - VehicleStatus status
    - String currentDestination
    - String currentLoadType
    - Double currentLoadQuantity
    - LocalDateTime lastActive
    --
    + void startMission(String destination)
    + void endMission()
    + boolean isAvailable()
    + double getTotalMobileStockQuantity()
  }

  ' ----- MOBILE STOCK ITEM (Inside Truck) -----
  class MobileStockItem {
    - Long id
    - String name
    - Brand brand
    - String bottleSize
    - int quantity
    --
    + void addStock(int qty)
    + void removeStock(int qty)
    + boolean hasEnoughStock(int requestedQty)
  }

  ' ----- TRANSACTION -----
  class Transaction {
    - Long id
    - LocalDateTime date
    - TransactionType type
    - ProductType productType
    - double quantity
    - String unit
    - double priceTotal
    - Double originalAmount
    - Currency currency
    - double exchangeRate
    - String partnerName
    - String truckPlate
    - Double acidity
    - Double waxes
    - String details
    - String gpsLocation
    - PaymentMethod paymentMethod
    - PaymentStatus paymentStatus
    - Double amountPaid
    --
    + double getAmountDue()
    + double getAmountInMAD()
    + boolean isPaid()
    + boolean isPartiallyPaid()
    + boolean isSale()
    + boolean isPurchase()
  }

  ' ----- TANK DISTRIBUTION (Multi-Tank per Transaction) -----
  class TankDistribution {
    - Long id
    - double quantity
    --
    + double getQuantity()
  }

  ' ----- EXPENSE -----
  class Expense {
    - Long id
    - LocalDateTime date
    - ExpenseCategory category
    - String description
    - double amount
    - PaymentMethod paymentMethod
    --
    + boolean isIncome()
    + boolean isTransfer()
  }

  ' ----- CHECK (CHEQUE) -----
  class BankCheck {
    - Long id
    - String number
    - String bank
    - double amount
    - LocalDate dueDate
    - CheckStatus status
    - CheckDirection direction
    - String partnerName
    --
    + boolean isOverdue()
    + boolean isDueSoon(int daysThreshold)
    + boolean isReceivable()
  }

  ' ----- BANK ACCOUNT -----
  class BankAccount {
    - Long id
    - String bankName
    - String accountNumber
    - Currency currency
    - double balance
    --
    + void deposit(double amount)
    + void withdraw(double amount)
    + boolean hasSufficientFunds(double amount)
    + double getBalanceInMAD(double exchangeRate)
  }

  ' ----- EMPLOYEE -----
  class Employee {
    - Long id
    - String name
    - EmployeeRole role
    - double baseSalary
    - boolean isActive
    --
    + boolean isWorker()
    + boolean isEmployee()
    + double getDailySalary()
  }

  ' ----- ATTENDANCE RECORD -----
  class AttendanceRecord {
    - Long id
    - LocalDate date
    - AttendanceStatus status
    - double hoursNormal
    - double hoursOvertime
    - Double advanceAmount
    --
    + double getEffectiveHours()
    + double getDayCoefficient()
    + boolean wasPresent()
  }

  ' ----- SALARY PAYMENT -----
  class SalaryPayment {
    - Long id
    - LocalDate periodStart
    - LocalDate periodEnd
    - double amount
    - PaymentMethod method
    - LocalDateTime paymentDate
    --
    + boolean isPaid()
    + String getPeriodLabel()
  }

  ' ----- FUEL LOG -----
  class FuelLog {
    - Long id
    - LocalDateTime date
    - FuelLogType type
    - double quantity
    - Double cost
    - String driverName
    - String plateNumber
    - double currentStockAfter
    --
    + boolean isPurchase()
    + boolean isConsumption()
    + Double getCostPerLiter()
  }

  ' ----- CONTRACT -----
  class Contract {
    - Long id
    - String reference
    - String clientName
    - ProductType productType
    - double targetQuantity
    - double targetAcidity
    - double targetWaxes
    - double priceSell
    - ContractStatus status
    - LocalDateTime createdAt
    --
