    + double getProgressPercentage()
    + double getWeightedAvgAcidity()
    + double getWeightedAvgWaxes()
    + double getTotalRevenue()
    + double getTotalCost()
    + double getProfit()
    + double getProfitMargin()
    + void checkAndUpdateStatus()
  }

  ' ----- CONTRACT ALLOCATION -----
  class ContractAllocation {
    - Long id
    - LocalDateTime date
    - String sourceName
    - double quantity
    - double acidity
    - double waxes
    - double costPrice
    --
    + double getAllocationRevenue(double priceSell)
    + double getAllocationProfit(double priceSell)
  }

  ' ----- INVOICE -----
  class Invoice {
    - Long id
    - String number
    - LocalDate date
    - String clientName
    - String clientAddress
    - String clientIce
    - double totalHT
    - double tvaRate
    - double tvaAmount
    - double totalTTC
    - String amountInWords
    - String paymentMode
    --
    + void recalculateTotals()
