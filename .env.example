# Copy this file to .env and fill in real values before running docker compose
# cp .env.example .env

# ── Neon PostgreSQL (external) ─────────────────────────────────────────────
# Full JDBC URL from your Neon project dashboard
# Format: jdbc:postgresql://<host>/<dbname>?sslmode=require
NEON_DATASOURCE_URL=jdbc:postgresql://<neon-host>/<dbname>?sslmode=require
NEON_DB_USERNAME=<neon-username>
NEON_DB_PASSWORD=<neon-password>

# ── JWT ────────────────────────────────────────────────────────────────────
# Must be at least 32 characters (256-bit)
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars
JWT_EXPIRATION_MS=86400000

# ── CORS ───────────────────────────────────────────────────────────────────
# The public URL of the frontend as seen by the browser
FRONTEND_ORIGIN=http://localhost:80

# ── Frontend runtime env (written to /env.js by docker-entrypoint.sh) ──────
# The API base URL as seen by the browser
VITE_API_BASE_URL=http://localhost:8080/api
# The WebSocket URL as seen by the browser
VITE_WEBSOCKET_URL=ws://localhost:8080/ws/alerts

# ── Tuning (optional) ──────────────────────────────────────────────────────
FUEL_LOW_STOCK_THRESHOLD=500
LOG_LEVEL=INFO
JAVA_OPTS=-Xms256m -Xmx512m -XX:+UseG1GC

